{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "jsx": "preserve"
  },
  "include": ["app/**/*.ts", "app/**/*.tsx"],
  "references": [
    {
      "path": "./app"
    }
  ]
}
